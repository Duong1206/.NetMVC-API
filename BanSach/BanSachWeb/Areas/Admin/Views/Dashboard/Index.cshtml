@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    :root {
        --primary-color: #0066cc;
        --success-color: #28a745;
        --warning-color: #ffc107;
        --danger-color: #dc3545;
        --info-color: #17a2b8;
        --light-bg: #f8f9fa;
        --card-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    body {
        background-color: var(--light-bg);
    }

    .dashboard-header {
        background: linear-gradient(135deg, var(--primary-color), #004ba3);
        color: white;
        padding: 30px;
        border-radius: 8px;
        margin-bottom: 30px;
        box-shadow: var(--card-shadow);
    }

    .dashboard-header h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 600;
    }

    .dashboard-header p {
        margin: 10px 0 0 0;
        opacity: 0.9;
    }

    /* Stat Cards */
    .stat-card {
        background: white;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: var(--card-shadow);
        transition: transform 0.3s, box-shadow 0.3s;
        border-left: 4px solid;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
    }

    .stat-card.primary {
        border-left-color: var(--primary-color);
    }

    .stat-card.success {
        border-left-color: var(--success-color);
    }

    .stat-card.warning {
        border-left-color: var(--warning-color);
    }

    .stat-card.info {
        border-left-color: var(--info-color);
    }

    .stat-card-icon {
        font-size: 2rem;
        margin-bottom: 10px;
    }

    .stat-card-title {
        font-size: 0.9rem;
        color: #666;
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .stat-card-value {
        font-size: 2rem;
        font-weight: 700;
        color: #333;
    }

    .stat-card-subtitle {
        font-size: 0.85rem;
        color: #999;
        margin-top: 5px;
    }

    /* Content Cards */
    .content-card {
        background: white;
        border-radius: 8px;
        padding: 25px;
        margin-bottom: 20px;
        box-shadow: var(--card-shadow);
    }

    .content-card h3 {
        font-size: 1.3rem;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid var(--light-bg);
    }

    /* Recent Orders Table */
    .table {
        margin-bottom: 0;
    }

    .table thead th {
        background-color: var(--light-bg);
        border-bottom: 2px solid #ddd;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        color: #666;
        padding: 15px;
    }

    .table tbody td {
        padding: 12px 15px;
        border-bottom: 1px solid #eee;
    }

    .table tbody tr:hover {
        background-color: var(--light-bg);
    }

    /* Status Badges */
    .badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .badge-success {
        background-color: #d4edda;
        color: #155724;
    }

    .badge-warning {
        background-color: #fff3cd;
        color: #856404;
    }

    .badge-danger {
        background-color: #f8d7da;
        color: #721c24;
    }

    .badge-info {
        background-color: #d1ecf1;
        color: #0c5460;
    }

    /* Top Products */
    .product-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 0;
        border-bottom: 1px solid #eee;
    }

    .product-row:last-child {
        border-bottom: none;
    }

    .product-name {
        font-weight: 600;
        color: #333;
    }

    .product-sales {
        color: var(--success-color);
        font-weight: 600;
    }

    /* Chart Container */
    .chart-container {
        position: relative;
        height: 300px;
        margin-bottom: 20px;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .dashboard-header {
            padding: 20px;
        }

        .dashboard-header h1 {
            font-size: 1.5rem;
        }

        .stat-card {
            margin-bottom: 15px;
        }

        .stat-card-value {
            font-size: 1.5rem;
        }

        .content-card {
            padding: 15px;
        }
    }
</style>

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="dashboard-header">
        <h1><i class="fas fa-chart-line"></i> Admin Dashboard</h1>
        <p>Welcome back! Here's your store performance overview.</p>
    </div>

    <!-- Key Metrics -->
    <div class="row">
        <div class="col-lg-3 col-md-6">
            <div class="stat-card primary">
                <div class="stat-card-icon"><i class="fas fa-money-bill-wave"></i></div>
                <div class="stat-card-title">Today Revenue</div>
                <div class="stat-card-value">₫@ViewData["RevenueToday"]</div>
                <div class="stat-card-subtitle">@ViewData["OrdersToday"] orders</div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card success">
                <div class="stat-card-icon"><i class="fas fa-calendar"></i></div>
                <div class="stat-card-title">This Month Revenue</div>
                <div class="stat-card-value">₫@ViewData["RevenueMonth"]</div>
                <div class="stat-card-subtitle">@ViewData["OrdersMonth"] orders</div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card warning">
                <div class="stat-card-icon"><i class="fas fa-chart-bar"></i></div>
                <div class="stat-card-title">This Year Revenue</div>
                <div class="stat-card-value">₫@ViewData["RevenueYear"]</div>
                <div class="stat-card-subtitle">@ViewData["OrdersYear"] orders</div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card info">
                <div class="stat-card-icon"><i class="fas fa-boxes"></i></div>
                <div class="stat-card-title">Total Products</div>
                <div class="stat-card-value">@ViewData["TotalProducts"]</div>
                <div class="stat-card-subtitle">In inventory</div>
            </div>
        </div>
    </div>

    <!-- Secondary Metrics -->
    <div class="row">
        <div class="col-lg-3 col-md-6">
            <div class="stat-card primary">
                <div class="stat-card-icon"><i class="fas fa-shopping-cart"></i></div>
                <div class="stat-card-title">Total Orders</div>
                <div class="stat-card-value">@ViewData["TotalOrders"]</div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card success">
                <div class="stat-card-icon"><i class="fas fa-star"></i></div>
                <div class="stat-card-title">Total Reviews</div>
                <div class="stat-card-value">@ViewData["TotalReviews"]</div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card warning">
                <div class="stat-card-icon"><i class="fas fa-users"></i></div>
                <div class="stat-card-title">Total Users</div>
                <div class="stat-card-value">@ViewData["TotalUsers"]</div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card info">
                <div class="stat-card-icon"><i class="fas fa-truck"></i></div>
                <div class="stat-card-title">Active Orders</div>
                <div class="stat-card-value">@(ViewBag.OrderStatusBreakdown.Count() > 0 ?
                                                            ViewBag.OrderStatusBreakdown[0].Count : 0)</div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Recent Orders -->
            <div class="col-lg-8">
                <div class="content-card">
                    <h3><i class="fas fa-list-ul"></i> Recent Orders</h3>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in (IEnumerable<dynamic>)ViewBag.RecentOrders)
                            {
                                <tr>
                                    <td>#@order.Id</td>
                                    <td>@order.CustomerName</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td>₫@order.OrderTotal.ToString("N0")</td>
                                    <td>
                                        <span class="badge @GetStatusBadgeClass(order.OrderStatus)">@order.OrderStatus</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Top Products -->
            <div class="col-lg-4">
                <div class="content-card">
                    <h3><i class="fas fa-fire"></i> Top Selling Products</h3>
                    @foreach (var product in (IEnumerable<dynamic>)ViewBag.TopProducts)
                    {
                        <div class="product-row">
                            <div>
                                <div class="product-name">@product.Name</div>
                                <small class="text-muted">₫@product.Price50.ToString("N0")</small>
                            </div>
                            <div class="product-sales">@product.SoldCount sold</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="row">
            <!-- New Customers -->
            <div class="col-lg-6">
                <div class="content-card">
                    <h3><i class="fas fa-user-plus"></i> New Customers</h3>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var customer in (IEnumerable<dynamic>)ViewBag.NewCustomers)
                            {
                                <tr>
                                    <td>@customer.Name</td>
                                    <td>@customer.Email</td>
                                    <td>@customer.PhoneNumber</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Revenue by Category -->
            <div class="col-lg-6">
                <div class="content-card">
                    <h3><i class="fas fa-tags"></i> Revenue by Category</h3>
                    @foreach (var category in (IEnumerable<dynamic>)ViewBag.RevenueByCategory)
                    {
                        <div class="product-row">
                            <div class="product-name">@category.Category</div>
                            <div class="product-sales">₫@category.Revenue.ToString("N0")</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Order Status Breakdown -->
            <div class="col-lg-6">
                <div class="content-card">
                    <h3><i class="fas fa-inbox"></i> Order Status</h3>
                    @foreach (var status in (IEnumerable<dynamic>)ViewBag.OrderStatusBreakdown)
                    {
                        <div class="product-row">
                            <div class="product-name">@(status.Status ?? "Unknown")</div>
                            <div class="product-sales">@status.Count orders</div>
                        </div>
                    }
                </div>
            </div>

            <!-- Payment Status Breakdown -->
            <div class="col-lg-6">
                <div class="content-card">
                    <h3><i class="fas fa-credit-card"></i> Payment Status</h3>
                    @foreach (var status in (IEnumerable<dynamic>)ViewBag.PaymentStatusBreakdown)
                    {
                        <div class="product-row">
                            <div class="product-name">@(status.Status ?? "Unknown")</div>
                            <div class="product-sales">@status.Count orders</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            function getStatusBadgeClass(status) {
                const classMap = {
                    'Đang xử lý': 'badge-info',
                    'Đã gửi': 'badge-warning',
                    'Đã giao': 'badge-success',
                    'Đã hủy': 'badge-danger'
                };
                return classMap[status] || 'badge-info';
            }
        </script>
    }

@functions {
    private string GetStatusBadgeClass(dynamic status)
    {
        var statusStr = status?.ToString() ?? "";
        return statusStr switch
        {
            "Đang xử lý" => "badge-info",
            "Đã gửi" => "badge-warning",
            "Đã giao" => "badge-success",
            "Đã hủy" => "badge-danger",
            _ => "badge-info"
        };
    }
}

@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="modern-auth-container">
    <div class="auth-card">
        <!-- Header Section -->
        <div class="auth-header">
            <i class="fas fa-book-open"></i>
            <h1>BanSach</h1>
            <p class="subtitle">Kho sách điện tử của bạn</p>
        </div>

        <!-- Login Form -->
        <form id="account" method="post" class="auth-form">
            <!-- Error Summary -->
            <div asp-validation-summary="ModelOnly" class="alert alert-danger form-alert" role="alert"></div>

            <!-- Email Field -->
            <div class="form-group">
                <label asp-for="Input.Email" class="form-label">
                    <i class="fas fa-envelope"></i> Email
                </label>
                <input asp-for="Input.Email" 
                       class="form-control form-control-modern" 
                       placeholder="Nhập email của bạn" 
                       autocomplete="username" 
                       aria-required="true" />
                <span asp-validation-for="Input.Email" class="text-danger form-error"></span>
            </div>

            <!-- Password Field -->
            <div class="form-group">
                <label asp-for="Input.Password" class="form-label">
                    <i class="fas fa-lock"></i> Mật khẩu
                </label>
                <div class="password-input-wrapper">
                    <input asp-for="Input.Password" 
                           class="form-control form-control-modern" 
                           placeholder="Nhập mật khẩu" 
                           autocomplete="current-password" 
                           aria-required="true"
                           type="password" 
                           id="passwordField" />
                    <button type="button" class="password-toggle" onclick="togglePassword()">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger form-error"></span>
            </div>

            <!-- Remember Me & Forgot Password -->
            <div class="auth-options">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" type="checkbox" id="rememberMe" />
                    <label class="form-check-label" for="rememberMe">
                        Ghi nhớ tôi
                    </label>
                </div>
                <a id="forgot-password" asp-page="./ForgotPassword" class="forgot-link">
                    Quên mật khẩu?
                </a>
            </div>

            <!-- Submit Button -->
            <button id="login-submit" type="submit" class="btn btn-modern btn-primary w-100">
                <i class="fas fa-sign-in-alt"></i> Đăng nhập
            </button>

            <!-- Divider -->
            <div class="auth-divider">
                <span>Hoặc</span>
            </div>

            <!-- Register Link -->
            <div class="auth-footer">
                <p>Chưa có tài khoản?</p>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-modern btn-outline w-100">
                    <i class="fas fa-user-plus"></i> Tạo tài khoản mới
                </a>
            </div>
        </form>
    </div>

    <!-- Decoration -->
    <div class="auth-decoration">
        <div class="deco-circle deco-1"></div>
        <div class="deco-circle deco-2"></div>
    </div>
</div>

<script>
    function togglePassword() {
        const field = document.getElementById('passwordField');
        const toggle = event.target.closest('.password-toggle');
        
        if (field.type === 'password') {
            field.type = 'text';
            toggle.innerHTML = '<i class="fas fa-eye-slash"></i>';
        } else {
            field.type = 'password';
            toggle.innerHTML = '<i class="fas fa-eye"></i>';
        }
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
